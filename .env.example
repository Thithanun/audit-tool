# ─────────────────────────────────────────────────────────────────────────────
# Audit Tool — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# Copy this file to .env.local and fill in your actual values.
#
# ห้าม commit .env.local ขึ้น git
# Never commit .env.local to git — it's already in .gitignore
# ─────────────────────────────────────────────────────────────────────────────


# ── Supabase Project URL ──────────────────────────────────────────────────────
# หาได้จาก: Supabase Dashboard → Project Settings → API → Project URL
# Find at:  Supabase Dashboard → Project Settings → API → Project URL
# รูปแบบ:   https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co


# ── Supabase Publishable (Anon) Key ──────────────────────────────────────────
# หาได้จาก: Supabase Dashboard → Project Settings → API → Project API keys → anon / public
# Find at:  Supabase Dashboard → Project Settings → API → anon public key
# ใช้ได้บน browser — ถูกปกป้องด้วย Row Level Security (RLS)
# Safe to expose to the browser — protected by Row Level Security policies
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here


# ── Supabase Service Role Key ─────────────────────────────────────────────────
# หาได้จาก: Supabase Dashboard → Project Settings → API → Project API keys → service_role
# Find at:  Supabase Dashboard → Project Settings → API → service_role key
#
# ⚠️  SECRET — ใช้ฝั่ง server เท่านั้น (Server Actions)
# ⚠️  SECRET — server-side only (used in Server Actions for admin operations)
# ⚠️  อย่าตั้งชื่อเป็น NEXT_PUBLIC_ เด็ดขาด — จะทำให้ key รั่วไปบน browser
# ⚠️  Never prefix with NEXT_PUBLIC_ — that would leak it to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
