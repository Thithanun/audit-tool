# ─────────────────────────────────────────────────────────────────────────────
# Audit Tool — On-Premise Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริงทุกช่องก่อนรัน install.sh
# Copy this file to .env and fill in ALL values before running install.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── โดเมนและ SSL ─────────────────────────────────────────────────────────────
# โดเมนหรือ hostname ของเซิร์ฟเวอร์ (ใช้ใน Nginx server_name + SSL cert)
# Domain or hostname of the server (used in Nginx server_name + SSL cert)
DOMAIN=audit.example.com

# วิธีออก SSL certificate:
#   letsencrypt (ค่าเริ่มต้น) — ขอ cert อัตโนมัติจาก Let's Encrypt
#     ต้องการ: DOMAIN ชี้ไปที่ public IP ของเครื่องนี้จริง และเปิด port 80 รับจากอินเทอร์เน็ตได้
#     ใช้ไม่ได้กับ server ภายในองค์กร (internal-only / ไม่มี public IP)
#   custom — ใช้ certificate ที่องค์กรออกให้เอง (เหมาะกับ server ภายในองค์กร)
#     ต้องระบุ SSL_CERT_FILE และ SSL_KEY_FILE ด้านล่างด้วย
SSL_MODE=letsencrypt

# อีเมลสำหรับ Let's Encrypt (แจ้งเตือนเมื่อ cert ใกล้หมดอายุ)
# จำเป็นเฉพาะเมื่อ SSL_MODE=letsencrypt — ถ้าใช้ SSL_MODE=custom ไม่ต้องกรอก
LETSENCRYPT_EMAIL=admin@example.com

# ── Custom SSL Certificate (ใช้เมื่อ SSL_MODE=custom เท่านั้น) ───────────────
# ระบุ path บนเครื่อง server ไปยังไฟล์ certificate/key ที่องค์กรออกให้
# (ต้อง copy ไฟล์เหล่านี้ขึ้นไปไว้บน server ก่อนรัน install.sh)
# SSL_CERT_FILE=/home/ncradmin/certs/audit-tool-fullchain.pem
# SSL_KEY_FILE=/home/ncradmin/certs/audit-tool-privkey.pem
SSL_CERT_FILE=
SSL_KEY_FILE=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# รหัสผ่านสำหรับ user postgres (ตั้งเองได้เลย)
POSTGRES_PASSWORD=change_me_strong_password

# ── JWT Secret ───────────────────────────────────────────────────────────────
# สตริงสุ่มอย่างน้อย 32 ตัวอักษร — ใช้ร่วมกันทุก service
# Random string ≥ 32 chars — shared across all Supabase-compatible services
# สร้างด้วย: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# ── Supabase-compatible Keys (สร้างโดย install.sh อัตโนมัติ) ────────────────
# install.sh will generate these from JWT_SECRET — you can leave them blank
# or pre-fill if you already have values from the old Supabase project
ANON_KEY=
SERVICE_ROLE_KEY=

# ── GoTrue (Auth Service) ─────────────────────────────────────────────────────
# รหัสผ่านสำหรับ GoTrue database user
GOTRUE_DB_PASSWORD=change_me_gotrue_db_pass

# ── MinIO (Object Storage) ────────────────────────────────────────────────────
# Username/Password สำหรับ MinIO root user (เหมือน AWS Access Key)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password

# ── Source Code ──────────────────────────────────────────────────────────────
# install.sh จะ clone จาก GitHub ไปที่ /opt/audit-tool/source/ โดยอัตโนมัติ
#
# ถ้า clone source code ไว้เองแล้ว ให้ระบุ path ที่ package.json อยู่:
# (เช่น ถ้า clone แล้วได้ ~/audit-tool/audit-tool/ ให้ใส่ path นั้นเลย)
# APP_SOURCE_DIR=/home/ncradmin/audit-tool/audit-tool
APP_SOURCE_DIR=
GITHUB_BRANCH=main

# ── Next.js App ───────────────────────────────────────────────────────────────
# URL สาธารณะของระบบ (ต้องตรงกับ DOMAIN ด้านบน)
NEXT_PUBLIC_SITE_URL=https://audit.example.com

# ─────────────────────────────────────────────────────────────────────────────
# ค่าด้านล่างนี้ install.sh จะสร้างให้อัตโนมัติจากค่าด้านบน
# ไม่ต้องแก้ไขถ้าไม่จำเป็น
# ─────────────────────────────────────────────────────────────────────────────

# ค่าด้านล่างนี้ install.sh จะเติมให้อัตโนมัติ — เว้นว่างไว้ได้เลย
# install.sh will fill in these values automatically — leave them blank.
NEXT_PUBLIC_SUPABASE_URL=https://audit.example.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
